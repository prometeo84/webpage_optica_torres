# --- Global security and performance configuration
Options -Indexes
ServerSignature Off

# Force HTTPS (except local dev)
RewriteEngine On

# Exclude static assets and known resource paths from further rewrite rules
<IfModule mod_rewrite.c>
  # Evita que reglas posteriores afecten a recursos estáticos
  RewriteRule ^(assets/|especialistas/|robots.txt|sitemap.xml|favicon.*)$ - [L]
</IfModule>
RewriteCond %{HTTPS} off
RewriteCond %{HTTP_HOST} !^(localhost|127\.0\.0\.1)(:\d+)?$ [NC]
RewriteRule ^ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

# Limit allowed HTTP methods
<LimitExcept GET POST HEAD>
  Require all denied
</LimitExcept>

# Block access to common sensitive files
<FilesMatch "^(?:\.env|composer\.json|composer\.lock|package\.json|package-lock\.json|gulpfile\.js|webpack\.config\.js|\.git|\.gitignore|README\.md)$">
  Require all denied
</FilesMatch>
RedirectMatch 403 (?i)/\.git(/|$)
RedirectMatch 403 (?i)/\.env(/|$)

# Prevent TRACE/TRACK
RewriteCond %{REQUEST_METHOD} ^(TRACE|TRACK)
RewriteRule .* - [F]

# Security headers
<IfModule mod_headers.c>
  <If "%{HTTPS} == 'on' && %{HTTP_HOST} !~ /^(localhost|127\\.0\\.0\\.1)(:\\d+)?$/">
    Header always set Strict-Transport-Security "max-age=63072000; includeSubDomains; preload"
  </If>
  Header always set X-Frame-Options "SAMEORIGIN"
  Header always set X-Content-Type-Options "nosniff"
  Header always set Referrer-Policy "no-referrer-when-downgrade"
  Header always set Permissions-Policy "geolocation=(), microphone=(), camera=()"
  Header set X-Robots-Tag "index, follow"

  # Content Security Policy (adjust as needed for external providers)
  Header always set Content-Security-Policy "default-src 'self' https: data:; script-src 'self' 'unsafe-inline' https:; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com https:; font-src 'self' https://fonts.gstatic.com https://cdnjs.cloudflare.com https://cdn.jsdelivr.net data:; img-src 'self' data: https://*.dailymotion.com https://*.dmcdn.net https:; frame-src 'self' https://www.dailymotion.com https://geo.dailymotion.com https://player.vimeo.com https://www.google.com https://maps.google.com; connect-src 'self' https:;"
</IfModule>

# --- Compression: Brotli (if available) + Gzip (mod_deflate)
<IfModule mod_brotli.c>
  AddOutputFilterByType BROTLI_COMPRESS text/html text/plain text/xml text/css application/javascript application/json image/svg+xml
</IfModule>
<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/html text/plain text/xml text/css application/javascript application/json
  SetEnvIfNoCase Request_URI "\.(?:gif|jpe?g|png|mp4|webm|ogg|zip|gz|br)$" no-gzip dont-vary
</IfModule>
<IfModule mod_headers.c>
  Header append Vary Accept-Encoding
</IfModule>

# Optional: serve pre-compressed .br/.gz files if present (uncomment if you generate them)
#<IfModule mod_rewrite.c>
#  RewriteEngine On
#  RewriteCond %{HTTP:Accept-encoding} br
#  RewriteCond %{REQUEST_FILENAME}.br -f
#  RewriteRule ^(.*) $1.br [L]
#</IfModule>

# --- Caching: Expires and Cache-Control for static assets
<IfModule mod_expires.c>
  ExpiresActive On
  ExpiresByType image/webp "access plus 1 year"
  ExpiresByType image/jpg "access plus 1 year"
  ExpiresByType image/jpeg "access plus 1 year"
  ExpiresByType image/gif "access plus 1 year"
  ExpiresByType image/png "access plus 1 year"
  ExpiresByType text/css "access plus 1 month"
  ExpiresByType application/javascript "access plus 1 month"
  ExpiresByType application/x-javascript "access plus 1 month"
  ExpiresByType text/html "access plus 0 seconds"
  ExpiresByType application/font-woff2 "access plus 1 year"
</IfModule>

<IfModule mod_headers.c>
  <FilesMatch "\.(ico|jpg|jpeg|png|gif|webp|svg|css|js|woff2|woff)$">
    Header set Cache-Control "public, max-age=31536000, immutable"
  </FilesMatch>
  <FilesMatch "\.(html|htm)$">
    Header set Cache-Control "public, max-age=0, must-revalidate"
  </FilesMatch>
</IfModule>

<FilesMatch "\.(ico|jpg|jpeg|png|gif|webp|svg|css|js|woff2|woff)$">
  SetEnv IS_STATIC 1
</FilesMatch>

# Ensure static files are explicitly allowed (Apache 2.4+ / fallback)
<IfModule mod_authz_core.c>
  <FilesMatch "\.(css|js|jpg|jpeg|png|gif|webp|svg|ico|woff2|woff)$">
    Require all granted
  </FilesMatch>
</IfModule>
<IfModule !mod_authz_core.c>
  <FilesMatch "\.(css|js|jpg|jpeg|png|gif|webp|svg|ico|woff2|woff)$">
    Order allow,deny
    Allow from all
  </FilesMatch>
</IfModule>

# --- Keep friendly .html rewrites
RewriteCond %{THE_REQUEST} \s([^\s]+)\.html [NC]
RewriteRule ^(.+)\.html$ /$1 [R=301,L]
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^(.+?)/?$ $1.html [L]

<IfModule mod_autoindex.c>
  IndexOptions -FancyIndexing -IconsAreLinks
</IfModule>

<Files ~ "^.*\.(bak|config|sql|psd|ini|log)$">
  Require all denied
</Files>
