# Seguridad global para el sitio
# - Evita listado de directorios
Options -Indexes

# Evita que se muestren errores del servidor y el banner (si es soportado)
ServerSignature Off

# Forzar HTTPS (redirección 301) — excepto en entornos locales (localhost / 127.0.0.1)
RewriteEngine On
# Solo redirigir a HTTPS si no es localhost o 127.0.0.1
RewriteCond %{HTTPS} off
RewriteCond %{HTTP_HOST} !^(localhost|127\.0\.0\.1)(:\d+)?$ [NC]
RewriteRule ^ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

# Limitar métodos HTTP permitidos
# Permite solo GET, POST, HEAD
<LimitExcept GET POST HEAD>
  Require all denied
</LimitExcept>

# Evitar listado y acceso a archivos sensibles
<FilesMatch "^(?:\.env|composer\.json|composer\.lock|package\.json|package-lock\.json|gulpfile\.js|webpack\.config\.js|\.git|\.gitignore|README\.md)$">
  Require all denied
</FilesMatch>

# Bloquear acceso a directorios sensibles y archivos de configuración
RedirectMatch 403 (?i)/\.git(/|$)
RedirectMatch 403 (?i)/\.env(/|$)

# Prevenir solicitudes TRACE/TRACK
RewriteCond %{REQUEST_METHOD} ^(TRACE|TRACK)
RewriteRule .* - [F]

# Evitar que archivos .php sean descargados por navegadores si hay exposición
<FilesMatch "\.(php|phar)$">
  <IfModule mod_authz_core.c>
    Require all granted
  </IfModule>
</FilesMatch>

# Cabeceras de seguridad recomendadas
<IfModule mod_headers.c>
  # HSTS: aplicar solo cuando la conexión es HTTPS y no estamos en localhost
  <If "%{HTTPS} == 'on' && %{HTTP_HOST} !~ /^(localhost|127\.0\.0\.1)(:\d+)?$/">
    Header always set Strict-Transport-Security "max-age=63072000; includeSubDomains; preload"
  </If>

  # X-Frame-Options
  Header always set X-Frame-Options "SAMEORIGIN"

  # Evitar sniffing MIME
  Header always set X-Content-Type-Options "nosniff"

  # Referrer policy
  Header always set Referrer-Policy "no-referrer-when-downgrade"

  # Content Security Policy ajustada: permite Google Fonts y dominios de Dailymotion
  # Ajusta si añades más CDNs o widgets externos
  Header always set Content-Security-Policy "default-src 'self' https: data:; script-src 'self' https: 'unsafe-inline'; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com https:; font-src 'self' https://fonts.gstatic.com data:; img-src 'self' data: https://*.dailymotion.com https://*.dmcdn.net https:; frame-src 'self' https://www.dailymotion.com https://geo.dailymotion.com https://player.vimeo.com; connect-src 'self' https:;"

  # Permissions Policy (antes Feature-Policy)
  Header always set Permissions-Policy "geolocation=(), microphone=(), camera=()"

  # X-Robots-Tag para evitar indexado accidental de directorios (opcional)
  Header set X-Robots-Tag "index, follow"
</IfModule>

###############################################################################
# Quitar .html globalmente: redirección externa + reescritura interna
###############################################################################

# 1) Redirigir peticiones explícitas a archivos .html hacia la URL limpia
RewriteCond %{THE_REQUEST} \s([^\s]+)\.html [NC]
RewriteRule ^(.+)\.html$ /$1 [R=301,L]

# 2) Si la URL solicitada no existe como archivo/dir, servir el .html correspondiente internamente
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^(.+?)/?$ $1.html [L]

# Evitar enumeración de archivos por parte de Apache (algún hosting ignora Options)
<IfModule mod_autoindex.c>
  IndexOptions -FancyIndexing -IconsAreLinks
</IfModule>

# Evitar acceso directo a archivos del sistema
<Files ~ "^.*\.(bak|config|sql|psd|ini|log)$">
  Require all denied
</Files>
